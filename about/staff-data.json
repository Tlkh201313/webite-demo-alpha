[
  {
    "id": "senior-leadership-team-slt",
    "title": "Senior Leadership Team (SLT)",
    "members": [
      {
        "name": "Claire Mills",
        "roles": [
          "Principal"
        ],
        "email": "Head@northstowe.education",
        "bio": "Claire began teaching in 2004 after training in Manchester, and has worked in schools across England including South Yorkshire, East Yorkshire, Derbyshire and Oxfordshire. Claire completed her postgraduate diploma in Innovation in Education at Warwick University in 2012 and her Masters degree in Teaching and Learning in Sheffield University in 2014. Claire joined Meridian Trust in 2018 as Deputy Headteacher at Swavesey Village College, taking on the role of Acting Headteacher for the 2022-2023 academic year. Whilst at Swavesey Village College, Claire was an integral part of the team that saw the school continued to gain an Ofsted Outstanding grading in all areas. Claire is passionate about inclusion and high-quality pastoral support, knowing and valuing all students to enable them to achieve their best in the classroom and beyond. Prior to becoming a teacher, Claire was a research scientist in molecular biology and genetics, gaining her doctorate from the ETH Zürich, Switzerland.",
        "image": "../assets/staff/Claire-Mills-scaled.jpg",
        "type": "leadership"
      },
      {
        "name": "Martin Campbell",
        "roles": [
          "Executive Principal"
        ],
        "email": "mcampbell@meridiantrust.co.uk",
        "bio": "A teacher since 1997 Martin worked at Cambridge Meridian Academies Trust (CMAT) in a variety of roles; a consultant, Head Teacher of North Cambridge Academy and as an Executive Principal. Prior to joining CMAT he was Headteacher of Kettering Science Academy – an all through school for ages 4 to 18, Vice Principal at Parkside Community College and Head of English at Coleridge Community College. Following the successful merger of Cambridge Primary Education Trust and CMAT, Martin continues to work as a secondary Executive Principal for Meridian Trust. Whilst at North Cambridge Academy he oversaw significant improvements which ensured Ofsted graded the school as ‘Good’ with ‘Outstanding’ leadership on two occasions (2015 and 2019). Prior to being a teacher Martin had a number of occupations which have included: soldier in the Scots Guards with operational tours of Northern Ireland and Falklands in 1982, croupier in London, instructor of wind surfing and canoeing and manager in various hotels in the Savoie, France.",
        "image": "../assets/staff/Martin-Campbell-e1622547483800-1024x999.jpg",
        "type": "leadership"
      },
      {
        "name": "Zoe Tregear",
        "roles": [
          "Vice Principal Head of Dyson House"
        ],
        "email": "ZTregear@northstowe.education",
        "bio": "",
        "image": "../assets/staff/Zoe-Tregear-scaled.jpg",
        "type": "leadership"
      },
      {
        "name": "Simon Russell",
        "roles": [
          "Assistant Headteacher Designated Safeguarding Lead Head of Attenborough House"
        ],
        "email": "SRussell@northstowe.education",
        "bio": "Simon secured a PGCE at Loughborough University. Graduating in 2004, Simon moved to Cambridge to take up his first teaching post at Swavesey Village College. Simon was quickly promoted into variety of roles and has always been committed to achieving the best outcome for each student. Simon’s career changed in 2011, when he became Director of school and community sport. Through detailed strategic planning and clear vison, Simon has led a variety range of staff to meet high expectations and influence change. Simon worked across a range of schools across the trust and has achieved the NPQSL. Simon started and subsequently lead the Physical Education and Sport CMAT group, steering students’ progress through common systems, positive ethos and high aspirations. Simon was nominated and received a National award for Professional Practice by the Association of Physical Education (2017). Simon’s work at Northstowe Secondary College started in 2013. His knowledge and expertise were called upon in order to provide in-depth consultation to develop new sports strategies and building design. Now leading on ethos, Simon is keen to ensure all students, parents and staff feel supported in demonstrating our whole school values of kind, curious and hardworking.",
        "image": "../assets/staff/GM-0916083550264-scaled.jpg",
        "type": "leadership"
      },
      {
        "name": "Carl Deighton",
        "roles": [
          "Assistant Headteacher Head of Parks House"
        ],
        "email": "CDeighton@northstowe.education",
        "bio": "Carl is passionate about ensuring every child achieves their full potential. He trained to teach in 2009 and graduated with a PGCE at the University of Leicester. Carl has taught English in a variety of locations; Leicester, Peterborough, and Ramsey over the last 12 years. He was Director of Key Stage 3 and Head of English in his last position where he led the whole school curriculum for KS3 and successfully led an outstanding English department, achieving excellent A Level and GCSE results consistently for several years. Carl has been a pastoral leader, teaching and learning coordinator and literacy coordinator. He has successfully mentored new teachers and trainees who have become outstanding practitioners. He has researched on developing boys’ literacy and implemented strategies to improve attainment which was highly successful. Carl’s aim is for every child to achieve outstanding results whilst enjoying school and becoming empathetic, respectable citizens.",
        "image": "../assets/staff/Carl-Deighton.jpg",
        "type": "leadership"
      },
      {
        "name": "Adam Roberts",
        "roles": [
          "Assistant Headteacher Careers Lead Head of Glennie House"
        ],
        "email": "ARoberts@northstowe.education",
        "bio": "Adam is a Product Design graduate from Nottingham Trent University. After spending some time travelling and working with children in Cambodia, he came back to the UK to complete his PGCE at the University of Manchester. After qualifying, Adam moved back to his hometown of Cambridge to work as a Design & Technology teacher at Soham Village College. He quickly became a department lead and then went on to become the director of SEND and senior mental health lead. He also has experience of safeguarding and alternative provision.",
        "image": "../assets/staff/Adam-Roberts-scaled.jpg",
        "type": "leadership"
      }
    ],
    "count": 6
  },
